#!/bin/bash
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
BRIDGE_DIR="$SCRIPT_DIR/bridge"
PID_FILE="/tmp/vibelink-bridge.pid"
LOG_FILE="/tmp/vibelink-bridge.log"

start_direct() {
  if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
    echo "vibelink is already running (pid $(cat "$PID_FILE"))"
    return
  fi
  cd "$BRIDGE_DIR"
  if [ -f .env ]; then
    set -a; source .env; set +a
  fi
  nohup node dist/server.js > "$LOG_FILE" 2>&1 &
  echo $! > "$PID_FILE"
  echo "vibelink started (pid $!, log at $LOG_FILE)"
}

stop_direct() {
  if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
    kill "$(cat "$PID_FILE")"
    rm -f "$PID_FILE"
    echo "vibelink stopped"
  else
    echo "vibelink is not running"
    rm -f "$PID_FILE"
  fi
}

status_direct() {
  if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
    echo "vibelink is running (pid $(cat "$PID_FILE"))"
  else
    echo "vibelink is not running"
    rm -f "$PID_FILE"
  fi
  if command -v curl >/dev/null; then
    echo ""
    curl -s http://localhost:3400/debug 2>/dev/null | head -20 || true
  fi
}

case "$1" in
  start)
    if systemctl is-active vibelink >/dev/null 2>&1; then
      echo "vibelink is already running (systemd)"
    else
      start_direct
    fi
    ;;
  stop)
    if systemctl is-active vibelink >/dev/null 2>&1; then
      sudo systemctl stop vibelink
      echo "vibelink stopped (systemd)"
    else
      stop_direct
    fi
    ;;
  status)
    if systemctl is-active vibelink >/dev/null 2>&1; then
      systemctl status vibelink --no-pager
    else
      status_direct
    fi
    ;;
  regenerate-token)
    TOKEN=$(openssl rand -hex 32)
    sed -i "s/AUTH_TOKEN=.*/AUTH_TOKEN=$TOKEN/" "$BRIDGE_DIR/.env"
    if systemctl is-active vibelink >/dev/null 2>&1; then
      sudo systemctl restart vibelink
    elif [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
      kill "$(cat "$PID_FILE")"
      start_direct
    fi
    echo "new token: $TOKEN"
    ;;
  *)
    echo "usage: vibelink {start|stop|status|regenerate-token}"
    ;;
esac
