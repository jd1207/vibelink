# vibelink bridge configuration
# copy this to .env and fill in your values

# auth token — generate with: openssl rand -hex 32
AUTH_TOKEN=

# port for the bridge server
PORT=3400

# directories to scan for projects (comma-separated)
# SCAN_ROOTS=/home/youruser/projects,/home/youruser/repos

# unix socket path for MCP server communication
# IPC_SOCKET_PATH=/tmp/vibelink.sock

# max events to buffer per session for reconnection
# EVENT_BUFFER_SIZE=200
